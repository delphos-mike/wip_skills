#!/usr/bin/env bash
# Run Notion skill scripts via uv.
# Usage: scripts/run script_name.py [args...]
#
# uv reads PEP 723 inline metadata from each script to resolve
# dependencies. No venv or manual install needed.

set -e

SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ "$#" -lt 1 ]; then
    echo "Usage: $(basename "$0") script_name.py [args...]" >&2
    echo "Error: Missing script name." >&2
    echo "Available scripts:" >&2
    ls "$SCRIPTS_DIR"/*.py 2>/dev/null | xargs -n1 basename >&2
    exit 1
fi

SCRIPT="$1"
shift

if [ ! -f "$SCRIPTS_DIR/$SCRIPT" ]; then
    echo "Error: Script not found: $SCRIPT" >&2
    echo "Available scripts:" >&2
    ls "$SCRIPTS_DIR"/*.py 2>/dev/null | xargs -n1 basename >&2
    exit 1
fi

exec uv run "$SCRIPTS_DIR/$SCRIPT" "$@"
